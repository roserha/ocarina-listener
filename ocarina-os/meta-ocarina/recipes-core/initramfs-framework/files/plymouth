#!/bin/sh
# initramfs plymouth module

plymouth_enabled() {
    return 0
}

plymouth_run() {
    echo "PLYMOUTH: starting" > /dev/console
    mkdir -p /run/plymouth

    # wait for framebuffer to be ready
    i=0
    while [ ! -e /dev/fb0 ] && [ $i -lt 20 ]; do
        sleep 0.1
        i=$((i + 1))
    done

    echo "PLYMOUTH: fb0 ready" > /dev/console
    plymouthd --mode=boot --attach-to-session --pid-file=/run/plymouth/pid
    echo "PLYMOUTH: showing splash" > /dev/console
    plymouth show-splash
    echo "PLYMOUTH: done" > /dev/console
}

plymouth_stop() {
    plymouth quit
}